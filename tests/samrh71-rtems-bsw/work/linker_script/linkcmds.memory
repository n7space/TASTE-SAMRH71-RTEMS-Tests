MEMORY {
  ITCM      : ORIGIN = 0x00000000, LENGTH = 0x00020000
  DTCM      : ORIGIN = 0x20000000, LENGTH = 0x00040000
  INTFLASH  : ORIGIN = 0x10000000, LENGTH = 0x00020000
  INTSRAM   : ORIGIN = 0x21000000, LENGTH = 0x000B0000 - 0
  LOG       : ORIGIN = 0x21000000 + 0x000B7000 - 2 * 0 - 2 * 4096, LENGTH = 4096
  NOCACHE   : ORIGIN = 0x21000000 + 0x000C0000 - 0, LENGTH = 0
  SDRAM   : ORIGIN = 0x70000000, LENGTH = 0x04000000 - 0
  SDRAM_NOCACHE  : ORIGIN = 0x70000000 + 0x04000000 - 0, LENGTH =  0
}

bsp_section_rwbarrier_align = 0x80;
